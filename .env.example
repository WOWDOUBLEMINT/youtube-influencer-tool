# 复制本文件为 .env 并填写密钥（.env 已被 gitignore，勿提交）。
# 线上部署：在平台「环境变量 / Variables」里添加同名变量，无需上传 .env 文件。
#
# Vercel：Project → Settings → Environment Variables → Name: YOUTUBE_API_KEY
# Railway：项目 → Variables → New Variable
# 云主机 systemd：在 Environment= 或 EnvironmentFile= 中配置
# Docker：见仓库内 docker-compose.yml，或 docker run -e YOUTUBE_API_KEY=你的密钥 ...

# 必填：Google Cloud 启用 YouTube Data API v3 后的 API 密钥
YOUTUBE_API_KEY=

# 可选：与 YOUTUBE_API_KEY 二选一（若已设 YOUTUBE_API_KEY 可忽略）
# GOOGLE_API_KEY=

# 可选：简介中无正则邮箱时用 Gemini 辅助提取
# GEMINI_API_KEY=

# 可选：YouTube search.list 最大分页数（每页约 100 配额点；默认 6，勿过大以免日配额用尽）
# YOUTUBE_SEARCH_MAX_PAGES=6

# 可选：两次搜索完成之间的最短间隔（毫秒），防止连点；例如 90000 = 90 秒内只能搜一次
# YOUTUBE_SEARCH_MIN_INTERVAL_MS=0

# 可选：search.list 每翻一页后再等多少毫秒再请求下一页（不减少总配额，只降低瞬时 QPS）
# YOUTUBE_SEARCH_PAGE_DELAY_MS=0

# 可选：项目每日配额上限（点），仅用于日志与接口 usage 估算；与控制台一致时更准
# YOUTUBE_QUOTA_UNITS_PER_DAY=10000

# 可选：访问 Google API 超时（毫秒）
# GOOGLE_API_TIMEOUT_MS=60000

# 可选：HTTP(S) 代理，例如 http://127.0.0.1:7890
# HTTPS_PROXY=
